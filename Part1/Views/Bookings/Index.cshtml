@model IEnumerable<EventEase.ViewModels.BookingViewModel>

@{
    ViewData["Title"] = "Bookings";
}

<h1 class="mb-4">Bookings</h1>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<div class="card shadow-sm p-4 mb-4">

    <form method="get" asp-action="Index">

        <div class="row g-3">

            <div class="col-md-3">
                <label class="form-label">
                    Search Booking ID / Event Name
                </label>

                <input type="text"
                       name="searchString"
                       value="@ViewBag.SearchString"
                       class="form-control"
                       placeholder="Search..." />
            </div>

            <div class="col-md-2">
                <label class="form-label">
                    Start Date
                </label>

                <input type="date"
                       name="startDate"
                       value="@ViewBag.StartDate"
                       class="form-control" />
            </div>

            <div class="col-md-2">
                <label class="form-label">
                    End Date
                </label>

                <input type="date"
                       name="endDate"
                       value="@ViewBag.EndDate"
                       class="form-control" />
            </div>

            <div class="col-md-2">
                <label class="form-label">
                    Event Type
                </label>

                <select name="eventTypeId"
                        class="form-control"
                        asp-items="ViewBag.EventTypes">

                    <option value="">
                        All Event Types
                    </option>

                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label">
                    Venue Availability
                </label>

                <select name="isAvailable" class="form-control">

                    <option value="">
                        All
                    </option>

                    <option value="true"
                            selected="@(ViewBag.IsAvailable == "true")">
                        Available
                    </option>

                    <option value="false"
                            selected="@(ViewBag.IsAvailable == "false")">
                        Unavailable
                    </option>

                </select>
            </div>

            <div class="col-md-1 d-flex align-items-end">
                <button type="submit"
                        class="btn btn-primary w-100">
                    Search
                </button>
            </div>

        </div>

        <div class="mt-3">
            <a asp-action="Index"
               class="btn btn-secondary">
                Clear Filters
            </a>
        </div>

    </form>

</div>

<p>
    <a asp-action="Create"
       class="btn btn-success">
        Create New Booking
    </a>
</p>

<table class="table table-bordered table-striped table-hover">

    <thead class="table-dark">
        <tr>
            <th>Booking ID</th>
            <th>Event</th>
            <th>Event Type</th>
            <th>Venue</th>
            <th>Available</th>
            <th>Event Date</th>
            <th>Booking Date</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>

        @if (Model.Any())
        {
            @foreach (var item in Model)
            {
                <tr>

                    <td>@item.BookingId</td>

                    <td>@item.EventName</td>

                    <td>@item.EventTypeName</td>

                    <td>@item.VenueName</td>

                    <td>
                        @if (item.IsAvailable)
                        {
                            <span class="badge bg-success">
                                Available
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger">
                                Unavailable
                            </span>
                        }
                    </td>

                    <td>
                        @item.EventDate.ToString("dd MMM yyyy")
                    </td>

                    <td>
                        @item.BookingDate.ToString("dd MMM yyyy")
                    </td>

                    <td>

                        <a asp-action="Details"
                           asp-route-id="@item.BookingId"
                           class="btn btn-info btn-sm">
                            Details
                        </a>

                        <a asp-action="Edit"
                           asp-route-id="@item.BookingId"
                           class="btn btn-warning btn-sm">
                            Edit
                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@item.BookingId"
                           class="btn btn-danger btn-sm">
                            Delete
                        </a>

                    </td>

                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="8"
                    class="text-center">
                    No bookings found.
                </td>
            </tr>
        }

    </tbody>

</table>