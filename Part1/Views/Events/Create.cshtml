@model EventEase.Models.Event

@{
    ViewData["Title"] = "Create Event";
}

<h1>Create Event</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label>Event Type</label>

                <select asp-for="EventTypeId"
                        asp-items="ViewBag.EventTypeId"
                        class="form-control">

                    <option value="">
                        Select Event Type
                    </option>

                </select>
            </div>

            <div class="mb-3">
                <label asp-for="EventName" class="form-label"></label>
                <input asp-for="EventName" class="form-control" />
                <span asp-validation-for="EventName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="EventDate" class="form-label"></label>
                <input asp-for="EventDate" type="datetime-local" class="form-control" />
                <span asp-validation-for="EventDate" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="VenueId" class="form-label">Venue</label>
                <select asp-for="VenueId" class="form-select" asp-items="ViewBag.VenueId">
                    <option value="">-- Select Venue --</option>
                </select>
                <span asp-validation-for="VenueId" class="text-danger"></span>
            </div>



            <button type="submit" class="btn btn-success">Create Event</button>
            <a asp-action="Index" class="btn btn-secondary">Back</a>

        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}