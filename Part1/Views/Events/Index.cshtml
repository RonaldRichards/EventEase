@model IEnumerable<EventEase.Models.Event>

@{
    ViewData["Title"] = "Events";
}

<h1 class="text-center">Upcoming Events</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">+ Create Event</a>
</p>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">@item.EventName</h5>

                    <p class="card-text">
                        📅 @item.EventDate.ToShortDateString() <br />
                        📍 @item.Venue?.VenueName <br />
                        📝 @item.Description
                    </p>

                    <a asp-action="Details" asp-route-id="@item.EventId" class="btn btn-primary">View</a>
                    <a asp-action="Edit" asp-route-id="@item.EventId" class="btn btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.EventId" class="btn btn-danger">Delete</a>
                </div>
            </div>
        </div>
    }
</div>