@{
    ViewData["Title"] = "Dashboard";
}

<h1 class="text-center mb-4">Admin Dashboard</h1>

<div class="row text-center">
    <div class="col-md-4">
        <div class="card bg-primary text-white p-3">
            <h3>@ViewBag.TotalEvents</h3>
            <p>Total Events</p>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card bg-success text-white p-3">
            <h3>@ViewBag.TotalVenues</h3>
            <p>Total Venues</p>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card bg-danger text-white p-3">
            <h3>@ViewBag.TotalBookings</h3>
            <p>Total Bookings</p>
        </div>
    </div>
</div>

<h3 class="mt-5">Upcoming Events</h3>

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Date</th>
            <th>Venue</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in ViewBag.UpcomingEvents)
        {
            <tr>
                <td>@item.EventName</td>
                <td>@item.EventDate.ToShortDateString()</td>
                <td>@item.Venue?.VenueName</td>
            </tr>
        }
    </tbody>
</table>